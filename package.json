        "@ngx-translate/http-loader": "4.0.0",
        "@swimlane/ngx-charts": "^11.1.0",
        "bootstrap": "^4.3.1",
        "core-js": "2.6.3",
        "echarts": "^4.2.1",
        "hammerjs": "^2.0.8",
        "moment": "2.24.0",
        "ng-jhipster": "^0.11.5",
        "ng2-sticky-nav": "^9.0.0",
        "ngu-carousel": "^1.5.3",
        "ngx-cookie": "2.0.1",
        "ngx-echarts": "^4.1.1",
        "ngx-infinite-scroll": "^7.2.0",
        "ngx-scrollspy": "^1.2.1",
        "ngx-scrolltop": "^1.0.0",
        "ngx-sticky": "^2.0.1",
        "ngx-tinymce": "9.0.0",
        "ngx-webstorage": "^4.0.2",
        "rxjs": "^6.4.0",
        "sockjs-client": "1.3.0",
        "swagger-ui": "^3.52.0",
        "tinymce": "^5.8.2",
        "tslib": "1.10.0",
        "webstomp-client": "1.2.6",
        "zone.js": "^0.9.1"
    },
    "devDependencies": {
        "@angular/cli": "^8.3.29",
        "@angular/compiler": "^8.2.14",
        "@angular/compiler-cli": "^8.2.14",
        "@angular/router": "^8.2.14",
        "@ngtools/webpack": "^12.2.2",
        "@types/jest": "23.3.13",
        "@types/node": "10.12.18",
        "angular-router-loader": "0.8.5",
        "angular2-template-loader": "0.6.2",
        "autoprefixer": "9.4.6",
        "browser-sync": "^2.26.7",
        "browser-sync-webpack-plugin": "2.2.2",
        "cache-loader": "2.0.1",
        "codelyzer": "^5.2.2",
        "copy-webpack-plugin": "^9.0.1",
        "css-loader": "2.1.0",
        "file-loader": "3.0.1",
        "fork-ts-checker-webpack-plugin": "^6.3.2",
        "friendly-errors-webpack-plugin": "1.7.0",
        "generator-jhipster": "^7.1.0",
        "html-loader": "0.5.5",
        "html-webpack-plugin": "3.2.0",
        "husky": "^1.3.1",
        "jest": "^27.0.6",
        "jest-junit": "^6.4.0",
        "jest-preset-angular": "6.0.2",
        "jest-sonar-reporter": "2.0.0",
        "lint-staged": "8.1.0",
        "mini-css-extract-plugin": "0.5.0",
        "moment-locales-webpack-plugin": "1.0.7",
        "optimize-css-assets-webpack-plugin": "5.0.1",
        "postcss-loader": "3.0.0",
        "prettier": "1.16.1",
        "reflect-metadata": "0.1.13",
        "rimraf": "2.6.3",
        "sass": "^1.26.5",
        "sass-loader": "7.1.0",
        "semver": "^7.3.2",
        "simple-progress-webpack-plugin": "1.1.2",
        "style-loader": "0.23.1",
        "terser-webpack-plugin": "^1.4.5",
        "thread-loader": "2.1.1",
        "to-string-loader": "1.1.5",
        "ts-loader": "5.3.3",
        "tslint": "5.12.1",
        "tslint-config-prettier": "1.17.0",
        "tslint-loader": "3.6.0",
        "typescript": "~3.5",
        "webpack": "4.29.0",
        "webpack-cli": "3.3.11",
        "webpack-dev-server": "^4.0.0",
        "webpack-merge": "4.2.1",
        "webpack-notifier": "1.7.0",
        "webpack-visualizer-plugin": "0.1.11",
        "workbox-webpack-plugin": "3.6.3",
        "write-file-webpack-plugin": "4.5.0",
        "xml2js": "0.4.19"
    },
    "engines": {
        "node": ">=8.9.0"
    },
    "lint-staged": {
        "{,src/**/}*.{md,json,ts,css,scss}": [
            "prettier --write",
            "git add"
        ]
    },
    "scripts": {
        "prettier:format": "prettier --write \"{,src/**/}*.{md,json,ts,css,scss}\"",
        "lint": "tslint --project tsconfig.json -e 'node_modules/**'",
        "lint:fix": "npm run lint -- --fix",
        "ngc": "ngc -p tsconfig-aot.json",
        "cleanup": "rimraf target/{aot,www}",
        "clean-www": "rimraf target//www/app/{src,target/}",
        "start": "npm run webpack:dev",
        "start-tls": "npm run webpack:dev -- --env.tls",
        "serve": "npm run start",
        "build": "npm run webpack:prod",
        "test": "npm run lint && jest --coverage --logHeapUsage -w=2 --config src/test/javascript/jest.conf.js",
        "test:watch": "npm run test -- --watch",
        "webpack:dev": "npm run webpack-dev-server -- --config webpack/webpack.dev.js --inline --hot --port=3060 --watch-content-base --env.stats=minimal",
        "webpack:dev-verbose": "npm run webpack-dev-server -- --config webpack/webpack.dev.js --inline --hot --port=3060 --watch-content-base --profile --progress --env.stats=normal",
        "webpack:build:main": "npm run webpack -- --config webpack/webpack.dev.js --env.stats=minimal",
        "webpack:build": "npm run cleanup && npm run webpack:build:main",
        "webpack:prod:main": "npm run webpack -- --config webpack/webpack.prod.js --profile",
        "webpack:prod": "npm run cleanup && npm run webpack:prod:main && npm run clean-www",
        "webpack:test": "npm run test",
        "webpack-dev-server": "node --max_old_space_size=4096 node_modules/webpack-dev-server/bin/webpack-dev-server.js",
        "webpack": "node --max_old_space_size=4096 node_modules/webpack/bin/webpack.js"
    },
    "jestSonar": {
        "reportPath": "target/test-results/jest",
        "reportFile": "TESTS-results-sonar.xml"
    }
}
