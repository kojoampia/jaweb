{
    "name": "jojoaddison",
    "version": "0.3.4",
    "description": "Web Application for Jojo Addison Consultancy",
    "private": true,
    "license": "Apache 2.0",
    "cacheDirectories": [
        "node_modules"
    ],
    "dependencies": {
        "@angular/animations": "^8.2.14",
