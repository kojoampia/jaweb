version: '2.2'
services:
    jaweb:
        image: docker-registry.jojoaddison.net/jaweb:$JAWEB_VERSION
        container_name: www.jojoaddison.net
        hostname: www.jojoaddison.net
        restart: always
        depends_on:
            - jacmongodb
        environment:
            - HOSTNAME=www.jojoaddison.net
            - _JAVA_OPTIONS=-Xmx512m -Xms256m
            - SPRING_PROFILES_ACTIVE=prod
            - SPRING_DATA_MONGODB_URI=mongodb://masterjoda:$MONGODB_PASSWD@jacmongodb:27017
            - SPRING_DATA_MONGODB_DATABASE=jojoaddison
            - JHIPSTER_SLEEP=5 # gives time for the database to boot before the application
            - JHIPSTER_MAIL_FROM=info@jojoaddison.net
            - JHIPSTER_MAIL_BASE_URL=www.jojoaddison.net
            - SPRING_MAIL_HOST=smtp-relay.gmail.com
            - SPRING_MAIL_PORT=587
            - SPRING_MAIL_USERNAME=jedi@jojoaddison.net
            - SPRING_MAIL_PASSWORD=$JEDI_MAIL_PASSW
            - CONTENT_ROOT=/
            - CONTENT_DIRECTORY='content'
        ports:
            - 127.0.0.1:1980:8080
        volumes:
            - /etc/timezone:/etc/timezone:ro
            - /etc/localtime:/etc/localtime:ro
            - ./slides/:/app/resources/static/content/slide/
            - ./static/:/app/resources/static/static/
            - ./partners/:/app/resources/static/partner/
            - ./tinymce/:/app/resources/static/tinymce/
            - ./entrypoint.sh:/entrypoint.sh
        networks:
            - staponet
    jacmongodb:
        extends:
            file: ../../mongodb/single/docker-compose.yml
            service: prod-jojoaddison-mongodb
        networks:
           - staponet
networks:
   staponet:
      driver: bridge
      